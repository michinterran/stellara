{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [{ "source": "/(.*)", "destination": "/" }],
  "env": {
    "VITE_FIREBASE_API_KEY": "@stellara-firebase-api-key",
    "VITE_FIREBASE_AUTH_DOMAIN": "@stellara-firebase-auth-domain",
    "VITE_FIREBASE_PROJECT_ID": "@stellara-firebase-project-id",
    "VITE_FIREBASE_STORAGE_BUCKET": "@stellara-firebase-storage-bucket",
    "VITE_FIREBASE_MESSAGING_SENDER_ID": "@stellara-firebase-messaging-sender-id",
    "VITE_FIREBASE_APP_ID": "@stellara-firebase-app-id",
    "VITE_ANTHROPIC_API_KEY": "@stellara-anthropic-api-key",
    "VITE_APPLE_MUSIC_TOKEN": "@stellara-apple-music-token",
    "VITE_YOUTUBE_API_KEY": "@stellara-youtube-api-key"
  }
}
