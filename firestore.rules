rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function adminDoc(uid) {
      return get(/databases/$(database)/documents/admin_users/$(uid));
    }

    function isBootstrapSuperAdmin() {
      return isSignedIn()
        && request.auth.token.email != null
        && request.auth.token.email in [
          'benjamin@meta.camp',
          'michinterran@gmail.com'
        ];
    }

    function isApprovedAdmin() {
      return isSignedIn()
        && (
          isBootstrapSuperAdmin()
          || (
            adminDoc(request.auth.uid).data.status == 'active'
            && adminDoc(request.auth.uid).data.role != 'viewer'
          )
        );
    }

    function isSuperAdmin() {
      return isSignedIn()
        && (
          isBootstrapSuperAdmin()
          || (
            adminDoc(request.auth.uid).data.status == 'active'
            && adminDoc(request.auth.uid).data.role == 'super_admin'
          )
        );
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    match /galaxies/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }

    match /planets/{planetId} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == request.resource.data.ownerId;
    }

    match /public_galaxies/{userId} {
      allow read: if true;
      allow write: if isOwner(userId) || isApprovedAdmin();
    }

    match /featured_galaxies/{featuredGalaxyId} {
      allow read: if true;
      allow write: if isApprovedAdmin();
    }

    match /planet_stats/{docId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /planet_likes/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /planet_saves/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /galaxy_visits/{docId} {
      allow read: if isApprovedAdmin();
      allow write: if isSignedIn();
    }

    match /planet_landings/{docId} {
      allow read: if isApprovedAdmin();
      allow write: if isSignedIn();
    }

    match /admin_users/{uid} {
      allow read: if isApprovedAdmin();
      allow create, update, delete: if isSuperAdmin();
    }

    match /admin_notices/{id} {
      allow read, write: if isApprovedAdmin();
    }

    match /admin_documents/{id} {
      allow read, write: if isApprovedAdmin();
    }

    match /admin_settings/{id} {
      allow read: if isSignedIn();
      allow write: if isApprovedAdmin();
    }

    match /admin_error_logs/{id} {
      allow read: if isApprovedAdmin();
      allow write: if isSignedIn();
    }

    match /admin_audit_logs/{id} {
      allow read: if isApprovedAdmin();
      allow create: if isApprovedAdmin();
      allow update, delete: if false;
    }

    match /payments/{id} {
      allow read, write: if isApprovedAdmin();
    }

    match /api_usage_daily/{id} {
      allow read, write: if isApprovedAdmin();
    }
  }
}
