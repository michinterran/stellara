// firestore.rules
// Firebase 콘솔 → Firestore → 규칙 탭에 붙여넣기

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 유저 프로필: 본인만 읽기/쓰기, 다른 유저는 공개 필드만 읽기
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // 갤럭시: 공개 갤럭시는 누구나 읽기, 본인 갤럭시만 쓰기
    match /galaxies/{galaxyId} {
      allow read: if resource.data.isPublic == true || 
                     (request.auth != null && resource.data.uid == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // 행성(플레이리스트): 부모 갤럭시 공개 여부에 따름
    match /planets/{planetId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
                      get(/databases/$(database)/documents/galaxies/$(resource.data.galaxyId)).data.uid == request.auth.uid;
      allow create: if request.auth != null;
    }

    // 팔로우 관계: 본인만 생성/삭제, 읽기는 인증된 유저
    match /follows/{followId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.followerId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.followerId == request.auth.uid;
    }

    // 리액션(별 쏘기): 인증된 유저는 생성 가능, 본인만 삭제
    match /reactions/{reactionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // 저장된 행성: 본인만 읽기/쓰기
    match /savedPlanets/{docId} {
      allow read, write: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // 베타 신청: 누구나 생성, 읽기는 인증된 유저
    match /betaRequests/{docId} {
      allow create: if true;
      allow read: if request.auth != null;
    }
  }
}
